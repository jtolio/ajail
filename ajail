#!/usr/bin/env python3

import os
import sys
import shutil
import tempfile

from pathlib import Path
from datetime import datetime

USAGE = """\
ajail - a simple script to make using bubblewrap in a folder easier.

usage: ajail [OPTION]... [<COMMAND>...]

 --fs=<ROOT_FS>           specify the root fs to use. by default uses 'default'.
                          if ROOT_FS is not an absolute path, the name is looked
                          for at ~/.ajail/fs/<ROOT_FS>.
 --ro[=<DIR>]             wrap the provided directory in a temporary rw overlay.
                          if no directory is specified, cwd is assumed. DIR can
                          be absolute or relative. see --rol, --rw, and --hide.
 --rol[=<DIR>]            readonly locked. --ro but without the rw overlay.
 --rw[=<DIR>]             make changes to the provided directory persistent.
 --hide[=<DIR>]           make the provided directory appear empty.
 --mount=<SRC>,<DST>[,rw] mount SRC at DST. mounted with a temporary rw overlay
                          on top unless rw is provided for persistence.
 --fs-edit[=<DIR>]        make changes to the root filesystem persistent. if
                          <DIR> is provided, just that subtree.
 --home-edit[=<SUBDIR>]   a subset of --fs-edit, make just jail-home changes
                          persistent, optionally just a subdirectory.
 --no-net                 disable network access.
 --clone                  if the current directory is a source repository,
                          instead of mounting the current directory directly,
                          we will make a new clone of the source repository
                          and mount that. pushing from inside will update the
                          current directory's metadata.
 --dev=<DEV>              device to mount inside.
 --cap-add=<CAP>          capability to add.
 --bwrap-bin=<BIN>        bwrap binary to use.
 --quiet                  no status output.

if [<command>...] is not provided, defaults to 'bash'."""

AJAIL_DIR = Path.home() / ".ajail"
FS_DIR = AJAIL_DIR / "fs"


def nonalnum_replace(s, r):
    return "".join(c if c.isalnum() else r for c in s)


def mount_helper(exterior_path, interior_path, mount_type, show_status):
    exterior_path = str(Path(exterior_path).absolute())
    interior_path = str(Path(interior_path).absolute())
    mounts = {
        "ro": ["--overlay-src", exterior_path, "--tmp-overlay", interior_path],
        "rol": ["--ro-bind", exterior_path, interior_path],
        "rw": ["--bind", exterior_path, interior_path],
        "hide": ["--tmpfs", interior_path],
        "dev": ["--dev-bind", exterior_path, interior_path],
    }
    if mount_type not in mounts:
        raise Exception("unknown mount type: %r" % mount_type)
    if show_status:
        print("  %s -> %s (%s)" % (
            exterior_path if mount_type != "hide" else "_",
            interior_path, mount_type))
    return mounts[mount_type]


def clone_repo(fs_to_use, pwd, bwrap_bin):
    # make directory for independent clone
    clone_base = AJAIL_DIR / "clone"
    os.makedirs(str(clone_base), exist_ok=True)
    clone_dir = Path(tempfile.mkdtemp(
        dir=str(clone_base),
        prefix="%s-%s-" % (
            nonalnum_replace(str(pwd), '_'),
            datetime.now().strftime("%Y%m%d"))))

    # clone current .git to new directory inside a jail
    child = os.fork()
    if child == 0:
        os.chdir(clone_dir)
        run(fs_to_use=fs_to_use, pwd_type="rw", network=False, fs_edits=[],
            submounts=[("ro", str(pwd / ".git"), "/ajail/origin")],
            command=["git", "clone", "-q", "/ajail/origin", "."],
            bwrap_bin=bwrap_bin)
        raise Exception("unreachable")

    # wait for clone
    _, status = os.waitpid(child, 0)
    if not os.WIFEXITED(status) or os.WEXITSTATUS(status) != 0:
        print(f"Clone failed: {status}.", file=sys.stderr)
        sys.exit(1)

    return clone_dir


def run(fs_to_use, pwd_type, network, submounts, fs_edits, command,
        clone=False, env_override=False, show_status=False,
        bwrap_args=None, bwrap_bin="bwrap", caps=None):

    if fs_to_use.startswith("/"):
        fs_path = Path(fs_to_use)
    else:
        fs_path = FS_DIR / fs_to_use

    if not fs_path.exists():
        print("Error: root fs %r does not exist." % fs_to_use, file=sys.stderr)
        options = ""
        if FS_DIR.exists():
            options = ", ".join(
                repr(d.name) for d in FS_DIR.iterdir() if d.is_dir())
        if options:
            print("Available: " + options, file=sys.stderr)
        else:
            print("Please create a rootfs.", file=sys.stderr)
        sys.exit(1)

    pwd = Path.cwd()

    if clone and not (pwd / ".git").exists():
        print("Error: clone mode only works with git repos right now.",
              file=sys.stderr)
        sys.exit(1)

    bwrap_cmd = [
        bwrap_bin,
        "--unshare-all",  # default nothing

        # unshare-all only tries on some things. let's explicitly be even more
        # restrictive.
        "--unshare-user", "--unshare-cgroup",

        # network access
        "--share-net" if network else "--unshare-net",

        # user namespacing
        "--uid", "0", "--gid", "0",

        # clear environment
        "--clearenv",
    ]

    try:  # handle CVE-2017-5226 if the kernel doesn't have TIOCSTI disabled.
        if Path("/proc/sys/dev/tty/legacy_tiocsti").read_text().strip() != "0":
            bwrap_cmd.append("--new-session")
    except FileNotFoundError:
        bwrap_cmd.append("--new-session")

    # define new environment
    env = {
        "HOME": "/root", "USER": "root",
        "PATH": ("/root/.local/bin:/usr/local/sbin:/usr/local/bin:"
                 "/usr/sbin:/usr/bin:/sbin:/bin"),
        "TERM": os.environ.get("TERM", "xterm"),
        "IS_SANDBOX": "1",
    }

    if env_override:
        for name, val in os.environ.items():
            if name.startswith("AJAIL_ENV_"):
                env[name.removeprefix("AJAIL_ENV_")] = val

    for name, val in env.items():
        bwrap_cmd.extend(["--setenv", name, val])

    if show_status:
        print("ajail %s in %s" % (fs_to_use, str(pwd)))
        print("Networking:", "enabled" if network else "disabled")
        print("Mounts:")

    # mount root
    if "/" in fs_edits:
        bwrap_cmd.extend(mount_helper(fs_path, "/", "rw", show_status))
    else:
        bwrap_cmd.extend(mount_helper(fs_path, "/", "ro", show_status))
        for path in fs_edits:
            bwrap_cmd.extend(mount_helper(str(fs_path) + path, path, "rw", show_status))

    # essential mounts
    bwrap_cmd.extend([
        "--dev", "/dev", "--proc", "/proc", "--tmpfs", "/tmp", "--tmpfs", "/run"])

    if network:
        bwrap_cmd.extend([
            "--ro-bind", "/etc/resolv.conf", "/etc/resolv.conf",
        ])

    if clone and pwd_type in ("ro", "rw"):
        if show_status:
            print("  (Cloning new independent workspace...)")

        clone_dir = clone_repo(fs_to_use=fs_to_use, pwd=pwd, bwrap_bin=bwrap_bin)
        bwrap_cmd.extend(mount_helper(pwd / ".git", "/ajail/origin", pwd_type, show_status))
        bwrap_cmd.extend(mount_helper(clone_dir, pwd, pwd_type, show_status))

    else:
        bwrap_cmd.extend(mount_helper(pwd, pwd, pwd_type, show_status))

    # mount submounts
    for mount_type, src, dest in submounts:
        bwrap_cmd.extend(mount_helper(src, dest, mount_type, show_status))

    if show_status and caps:
        print("Caps:", " ".join(caps))
    for cap in (caps or []):
        bwrap_cmd.extend(["--cap-add", cap])

    bwrap_cmd.extend([
        # set hostname
        "--hostname", "ajail-" + nonalnum_replace(fs_to_use, "-") + ".localhost",

        # start in pwd if mounted
        "--chdir", str(pwd),
    ])

    if bwrap_args:
        if show_status:
            print("Other:\n ", " ".join(
                ("\n  " + arg if arg.startswith("-") and i > 0 else arg
                 for i, arg in enumerate(bwrap_args))))
        bwrap_cmd.extend(bwrap_args)

    bwrap_cmd.append("--")
    bwrap_cmd.extend(command)

    if show_status:
        print("Starting...\n")

    os.execvp(bwrap_cmd[0], bwrap_cmd)
    raise Exception("unreachable")


def main():
    args = sys.argv[1:]
    if os.environ.get("AJAIL_ARGS", ""):
        args = os.environ.get("AJAIL_ARGS").split(";") + args

    fs_to_use, bwrap_bin, pwd_type = "default", "bwrap", "rw"
    clone, show_status, network = False, True, True
    submounts, fs_edits, bwrap_args, caps, command = [], [], [], [], []
    pwd_mount_types = ("ro", "rw", "hide", "rol", "dev")

    # tight control over argument parsing
    while args:
        arg = args[0]
        if arg.startswith("--"): arg = arg[1:]

        if arg.startswith("-fs="):
            fs_to_use = arg.removeprefix("-fs=")
        elif arg.startswith("-") and arg[1:] in pwd_mount_types:
            pwd_type = arg[1:]
        elif any((arg.startswith("-%s=" % t) for t in pwd_mount_types)):
            eq = arg.find("=")
            submounts.append((arg[1:eq], arg[eq+1:], arg[eq+1:]))
        elif arg.startswith("-mount="):
            parts = arg.removeprefix("-mount=").split(",")
            if len(parts) == 2:
                submounts.append(("ro", parts[0], parts[1]))
            elif len(parts) == 3 and parts[2] in pwd_mount_types:
                submounts.append((parts[2], parts[0], parts[1]))
            else:
                print(USAGE)
                sys.exit(1)
        elif arg == "-fs-edit" or arg.startswith("-fs-edit="):
            fs_edits.append("/" + arg.removeprefix("-fs-edit").removeprefix("=").removeprefix("/"))
        elif arg == "-home-edit" or arg.startswith("-home-edit="):
            fs_edits.append("/root/" + arg.removeprefix("-home-edit").removeprefix("="))
        elif arg == "-no-net": network = False
        elif arg == "-clone": clone = True
        elif arg == "-quiet": show_status = False
        elif arg.startswith("-bw="):
            bwrap_args.append(arg.removeprefix("-bw="))
        elif arg.startswith("-bwrap-bin="):
            bwrap_bin = arg.removeprefix("-bwrap-bin=")
        elif arg.startswith("-cap-add="):
            caps.append(arg.removeprefix("-cap-add="))
        elif arg == "-":
            command = args[1:]
            break
        elif arg.startswith("-"):
            print(USAGE)
            sys.exit(1)
        else:
            command = args
            break
        args = args[1:]

    if not command:
        command = ["bash"]

    run(fs_to_use=fs_to_use, pwd_type=pwd_type, network=network,
        submounts=submounts, fs_edits=fs_edits, command=command, clone=clone,
        env_override=True, show_status=show_status, bwrap_args=bwrap_args,
        bwrap_bin=bwrap_bin, caps=caps)
    raise Exception("unreachable")


if __name__ == "__main__":
    main()
